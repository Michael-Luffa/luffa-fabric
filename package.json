{
  "name": "@luffa/fabric",
  "version": "0.1.0",
  "description": "Luffa Fabric Phase 1 MVP 2 multi-chain agent execution and settlement layer.",
  "author": "Luffa AI Research Lab",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lael-mcp": "dist/mcp/server.js",
    "luffa-fabric-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "demo": "node dist/demo.js",
    "demo:visual": "vite visual-demo --host 127.0.0.1",
    "test": "vitest run tests",
    "test:unit": "vitest run tests/wallet.test.ts tests/chains.test.ts tests/settlement-adapters.test.ts tests/execution-ledger.test.ts tests/security.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:e2e": "vitest run tests/e2e",
    "test:wallet": "vitest run tests/wallet.test.ts",
    "test:settlement": "vitest run tests/settlement-adapters.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.3",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "fastify": "^5.2.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2",
    "vite": "4.5.14",
    "vitest": "0.34.6"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT"
}
